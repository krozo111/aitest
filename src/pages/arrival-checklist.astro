---
import Layout from '../layouts/Layout.astro';
import { getResidents, updateResidentCheckout } from '../lib/airtable';

let residents = [];
let error = null;
let successMessage = null;

if (Astro.request.method === 'POST') {
    try {
        const data = await Astro.request.formData();
        const action = data.get('action')?.toString();

        if (action === 'checkout') {
            const recordId = data.get('recordId')?.toString();
            const formName = data.get('name')?.toString() || '';
            const isCheckout = data.get('checkout') === 'on';

            await updateResidentCheckout(recordId, isCheckout);
            successMessage = `Checkbox modified for ${formName}!`;
        }
    } catch (e) {
        if (e instanceof Error) {
            error = e.message;
        } else {
            error = 'An unexpected error occurred while processing the request.';
        }
    }
}

try {
    residents = await getResidents();
    // Ordenar por número de cuarto
    residents.sort((a: any, b: any) => {
        const numA = parseInt(a.room);
        const numB = parseInt(b.room);
        if (!isNaN(numA) && !isNaN(numB)) return numA - numB;
        return String(a.room).localeCompare(String(b.room));
    });
} catch (e) {
    if (e instanceof Error) error = e.message;
}
---

<Layout>
    <main class="container">
        <div class="glass-card table-card">
            
            <header>
                <h1>Resident Checkout</h1>
                <p>Search for a resident and complete their checkout process.</p>
            </header>

            {error && (
                <div class="alert error-message">
                    {error}
                </div>
            )}

            {successMessage && (
                <div class="alert success-message-inline">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    <span>{successMessage}</span>
                </div>
            )}

            <div class="search-bar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" id="searchInput" placeholder="Search by name or room number..." />
            </div>

            <div class="table-responsive">
                <table class="residents-table">
                    <thead>
                        <tr>
                            <th>Room</th>
                            <th>Name</th>
                            <th>Checkout</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="residentsBody">
                        {residents.map((resident: any) => (
                            <tr class="resident-row">
                                <td class="td-room"><strong>{resident.room}</strong></td>
                                <td class="td-name">{resident.name}</td>
                                <td>
                                    <form method="POST" class="checkout-form" id={`form-${resident.id}`}>
                                        <input type="hidden" name="action" value="checkout" />
                                        <input type="hidden" name="recordId" value={resident.id} />
                                        <input type="hidden" name="name" value={resident.name} />
                                        
                                        <div class="checkbox-wrapper">
                                            <input 
                                                type="checkbox" 
                                                id={`chk-${resident.id}`} 
                                                name="checkout" 
                                                checked={resident.hasCheckedOut} 
                                                disabled={resident.hasCheckedOut} 
                                            />
                                            <label for={`chk-${resident.id}`}>
                                                {resident.hasCheckedOut ? "Completed" : "Complete"}
                                            </label>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    {resident.hasCheckedOut ? (
                                        <span class="status-done">✓ Done</span>
                                    ) : (
                                        <button type="submit" form={`form-${resident.id}`} class="btn-checkout">Update</button>
                                    )}
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
                
                {residents.length === 0 && !error && (
                    <div class="empty-state">No residents found in Airtable.</div>
                )}
            </div>

        </div>
    </main>
</Layout>

<style>
    .table-card {
        max-width: 1000px;
        width: 100%;
        padding: 2rem;
    }

    .alert {
        padding: 1rem 1.5rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-weight: 500;
    }

    .error-message {
        background: rgba(254, 84, 74, 0.1);
        border: 1px solid rgba(254, 84, 74, 0.3);
        color: var(--color-error);
    }

    .success-message-inline {
        background: rgba(80, 224, 191, 0.1);
        border: 1px solid rgba(80, 224, 191, 0.3);
        color: #2a8b74;
    }

    .success-message-inline svg {
        width: 24px;
        height: 24px;
        color: var(--color-primary);
    }

    .search-bar {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .search-bar svg {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        color: #a0a0a0;
    }

    .search-bar input {
        width: 100%;
        background: #ffffff;
        border: 2px solid #e6e6e6;
        border-radius: 50px;
        padding: 1rem 1rem 1rem 3rem;
        color: var(--color-text);
        font-size: 1rem;
        font-family: inherit;
        transition: all 0.3s ease;
    }

    .search-bar input:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 4px rgba(80, 224, 191, 0.2);
    }

    .table-responsive {
        width: 100%;
        overflow-x: auto;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e6e6e6;
        margin-top: 1rem;
    }

    .residents-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    .residents-table th {
        background: #f8f8f8;
        padding: 1rem 1.5rem;
        font-weight: 700;
        color: var(--color-text-muted);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #e6e6e6;
    }

    .residents-table td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #f0f0f0;
        vertical-align: middle;
        color: var(--color-text);
    }

    .resident-row:last-child td {
        border-bottom: none;
    }

    .resident-row:hover td {
        background-color: rgba(80, 224, 191, 0.05);
    }

    .td-room {
        font-size: 1.1rem;
        color: var(--color-bg);
    }

    .td-name {
        font-weight: 500;
    }

    .checkout-form {
        margin: 0;
        display: flex;
        align-items: center;
    }

    .checkbox-wrapper {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }

    .checkbox-wrapper input[type="checkbox"] {
        width: 20px;
        height: 20px;
        accent-color: var(--color-primary);
        cursor: pointer;
    }

    .checkbox-wrapper input[type="checkbox"]:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .checkbox-wrapper label {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        cursor: pointer;
        user-select: none;
    }

    .btn-checkout {
        background: var(--color-bg);
        color: #ffffff;
        border: none;
        border-radius: 50px;
        padding: 0.6rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: all 0.2s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .btn-checkout:hover {
        background: var(--color-primary);
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(80, 224, 191, 0.3);
    }

    .empty-state {
        padding: 3rem;
        text-align: center;
        color: var(--color-text-muted);
    }
</style>

<script>
    // Client-side filtering logic
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const residentsBody = document.getElementById('residentsBody');

    if (searchInput && residentsBody) {
        searchInput.addEventListener('input', function() {
            const filter = this.value.toLowerCase().trim();
            const rows = residentsBody.getElementsByClassName('resident-row');

            for (let i = 0; i < rows.length; i++) {
                const room = (rows[i].querySelector('.td-room') as HTMLElement).innerText.toLowerCase();
                const name = (rows[i].querySelector('.td-name') as HTMLElement).innerText.toLowerCase();
                
                if (room.includes(filter) || name.includes(filter)) {
                    (rows[i] as HTMLElement).style.display = '';
                } else {
                    (rows[i] as HTMLElement).style.display = 'none';
                }
            }
        });
    }
</script>
